<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) cloud-backup and device-transfer rules.
  Required by android:dataExtractionRules in AndroidManifest.
  Using <include> tags means everything else is excluded by default.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="scribe_db" />
        <include domain="sharedpref" path="scribe_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="scribe_db" />
        <include domain="sharedpref" path="scribe_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
