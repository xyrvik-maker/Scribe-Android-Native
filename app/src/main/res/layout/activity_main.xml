<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- ═══ Main content ═══════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top bar -->
        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_menu"
                android:contentDescription="Open menu" />

            <!-- Title area (center, grows) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Welcome" />

                <TextView
                    android:id="@+id/tv_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textSize="11sp"
                    tools:text="/Welcome.md" />

                <EditText
                    android:id="@+id/title_edit_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:imeOptions="actionDone"
                    android:singleLine="true" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_find"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_search"
                android:contentDescription="Find" />

            <ImageButton
                android:id="@+id/btn_more"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_more_vert"
                android:contentDescription="More options" />

            <ImageButton
                android:id="@+id/btn_sidebar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_sidebar"
                android:contentDescription="Outline panel" />
        </LinearLayout>

        <!-- Recovery banner -->
        <LinearLayout
            android:id="@+id/recovery_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="#FFF3CD"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Unsaved content found. Restore?"
                android:textSize="14sp"
                android:textColor="#664D03" />

            <Button
                android:id="@+id/btn_recovery_restore"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Restore"
                android:textColor="#664D03" />

            <Button
                android:id="@+id/btn_recovery_dismiss"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dismiss"
                android:textColor="#664D03" />
        </LinearLayout>

        <!-- Find & Replace bar -->
        <LinearLayout
            android:id="@+id/find_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <EditText
                    android:id="@+id/find_input"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:hint="Find…"
                    android:singleLine="true"
                    android:textSize="14sp"
                    android:background="@drawable/bg_find_input"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp" />

                <TextView
                    android:id="@+id/tv_match_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:paddingStart="8dp"
                    android:paddingEnd="4dp" />

                <ImageButton
                    android:id="@+id/btn_find_case"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_case"
                    android:alpha="0.4"
                    android:contentDescription="Case sensitive" />

                <ImageButton
                    android:id="@+id/btn_find_regex"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_regex"
                    android:alpha="0.4"
                    android:contentDescription="Regex" />

                <ImageButton
                    android:id="@+id/btn_find_prev"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_arrow_up"
                    android:contentDescription="Previous match" />

                <ImageButton
                    android:id="@+id/btn_find_next"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_arrow_down"
                    android:contentDescription="Next match" />

                <ImageButton
                    android:id="@+id/btn_find_close"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_close"
                    android:contentDescription="Close find" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/replace_input"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:hint="Replace…"
                    android:singleLine="true"
                    android:textSize="14sp"
                    android:background="@drawable/bg_find_input"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp" />

                <Button
                    android:id="@+id/btn_replace_one"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="6dp"
                    android:text="Replace"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btn_replace_all"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="6dp"
                    android:text="All"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Editor scroll container (fills remaining space) -->
        <ScrollView
            android:id="@+id/editor_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <com.primaloptima.scribe.view.ScribeEditText
                android:id="@+id/editor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top|start"
                android:background="@null"
                android:textCursorDrawable="@drawable/cursor_drawable"
                android:hint="Start writing…"
                android:padding="24dp"
                android:lineSpacingMultiplier="1.7"
                android:textIsSelectable="false"
                android:inputType="textMultiLine|textCapSentences"
                android:scrollbars="none" />
        </ScrollView>

        <!-- Word count badge (anchored above shortcut bar) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_word_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|bottom"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="4dp"
                android:textSize="11sp"
                android:alpha="0.7"
                tools:text="342 words" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_word_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|bottom"
                android:layout_margin="8dp"
                android:visibility="gone"
                app:fabSize="mini" />
        </FrameLayout>

        <!-- Shortcut bar (sticks above keyboard) -->
        <com.primaloptima.scribe.view.ShortcutBarView
            android:id="@+id/shortcut_bar"
            android:layout_width="match_parent"
            android:layout_height="44dp" />

    </LinearLayout>

    <!-- ═══ Left drawer — file tree ════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/left_drawer"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical">

        <!-- Book title header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="6dp">

            <TextView
                android:id="@+id/tv_vault_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"
                tools:text="My Book" />

            <ImageButton
                android:id="@+id/btn_close_drawer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                android:alpha="0.55"
                android:contentDescription="Close panel" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:alpha="0.08"
            android:background="#888888" />

        <!-- File tree -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_file_tree"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:alpha="0.08"
            android:background="#888888" />

        <!-- Bottom bar: Settings · Theme · Characters -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_drawer_settings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:src="@drawable/ic_settings"
                android:contentDescription="Settings" />

            <ImageButton
                android:id="@+id/btn_drawer_theme"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:src="@drawable/ic_folder"
                android:contentDescription="Themes" />

            <ImageButton
                android:id="@+id/btn_drawer_characters"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:src="@drawable/ic_edit"
                android:contentDescription="Characters &amp; Locations" />
        </LinearLayout>
    </LinearLayout>

    <!-- ═══ Right drawer — outline / pinned ════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/right_drawer"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical">

        <!-- Pinned top -->
        <FrameLayout
            android:id="@+id/pinned_top"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0"
            android:visibility="gone" />

        <!-- Divider between pinned slots -->
        <View
            android:id="@+id/pinned_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:visibility="gone" />

        <!-- Pinned bottom -->
        <FrameLayout
            android:id="@+id/pinned_bottom"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0"
            android:visibility="gone" />

        <!-- Outline header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="OUTLINE"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp" />

        <!-- Outline list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_outline"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
